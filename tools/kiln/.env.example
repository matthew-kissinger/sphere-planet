# Kiln Studio developer API — copy this file to `.env.local` and fill KILN_API_KEY.
# NEVER commit the real key. `.env.local` (and `.env`) must be gitignored.
# The key is an admin-issued DeveloperClient PAT of the form ks_live_...  (one-time display).

# REQUIRED. The ks_live_... personal access token. Goes in .env.local only.
KILN_API_KEY=

# Production private developer API. Leave as-is unless targeting a private environment.
KILN_API_URL=https://app.kilnstudio.tools/v1

# Where downloaded GLBs + sidecars are written. Path is resolved relative to this
# tools/kiln/ dir (scripts run from here), so `../../public/...` lands in the game's
# Vite-served public/ folder. Adjust the ../../ prefix if you move this kit.
KILN_OUT_DIR=../../public/assets/kiln/generated

# Optional: pin the sphere-planet palette on every generation for consistent color.
# Set this after running `node scripts/create-palette.mjs` (it prints the paletteId).
KILN_PALETTE_ID=sphere-planet

# Optional defaults for scripts/generate-asset.mjs
KILN_ASSET_CATEGORY=prop
KILN_ASSET_ROLE=prop

# Optional CloudFront edge-block retry tuning (defaults shown).
# KILN_EDGE_RETRIES=8
# KILN_EDGE_RETRY_MS=15000
