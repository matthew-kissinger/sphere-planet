    { "name": "wood",       "color": "#a8763f", "kind": "opaque", "roughness": 0.85, "use": "trunks, planks, structures, tools" },
    { "name": "stone-dark", "color": "#4f5257", "kind": "opaque", "roughness": 0.8, "use": "shadowed rock, deep stone, iron" },
